<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TaskManager - Gestor de Tareas</title>
    <base href="/">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="manifest" href="/manifest.json">
    <script type="text/javascript" src="/js/script.js"></script>
</head>
<body class="index-page">
    <div class="container">
        <!-- Landing Section -->
        <div class="landing-section">
            <h1>Lista de tareas</h1>
            <p>Organiza tu vida y aumenta tu productividad con nuestra plataforma de gestión de tareas.</p>
            
            <div class="features">
                <div class="feature">
                    <div class="feature-icon">✓</div>
                    <p>Crea, organiza y clasifica tus tareas fácilmente</p>
                </div>
                <div class="feature">
                    <div class="feature-icon">📊</div>
                    <p>Visualiza tu progreso con estadísticas en tiempo real</p>
                </div>
                <div class="feature">
                    <div class="feature-icon">🔔</div>
                    <p>Recibe notificaciones para tus tareas importantes</p>
                </div>
                <div class="feature">
                    <div class="feature-icon">🤝</div>
                    <p>Colabora con tu equipo en proyectos compartidos</p>
                </div>
                <div class="feature">
                    <div class="feature-icon">📱</div>
                    <p>Accede desde cualquier dispositivo</p>
                </div>
            </div>
        </div>

        <!-- Auth Section -->
        <div class="auth-section">
            <div class="form-container">
                <div class="tabs">
                    <button class="tab-button active" data-tab="login">Iniciar Sesión</button>
                    <button class="tab-button" data-tab="register">Registrarse</button>
                </div>

                <!-- Login Form -->
                <form class="form-content active" id="login" onsubmit="handleLogin(event)">
                    <div class="form-group">
                        <label for="login-email">Correo Electrónico</label>
                        <input type="email" id="login-email" placeholder="tu@correo.com" autocomplete="username" required>
                    </div>

                    <div class="form-group">
                        <label for="login-password">Contraseña</label>
                        <input type="password" id="login-password" placeholder="••••••••" autocomplete="current-password" required>
                    </div>

                    <button type="submit" class="submit-button">Iniciar Sesión</button>
                </form>

                <!-- Register Form -->
                <form class="form-content" id="register" onsubmit="handleRegister(event)">
                    <div class="form-group">
                        <label for="register-name">Nombre Completo</label>
                        <input type="text" id="register-name" placeholder="Juan Pérez" required>
                    </div>

                    <div class="form-group">
                        <label for="register-email">Correo Electrónico</label>
                        <input type="email" id="register-email" placeholder="tu@correo.com" autocomplete="username" required>
                    </div>

                    <div class="form-group">
                        <label for="register-password">Contraseña</label>
                        <input type="password" id="register-password" placeholder="••••••••" autocomplete="current-password" required>
                    </div>

                    <div class="form-group">
                        <label for="register-password-confirm">Confirmar Contraseña</label>
                        <input type="password" id="register-password-confirm" placeholder="••••••••" autocomplete="current-password" required>
                    </div>

                    <button type="submit" class="submit-button">Crear Cuenta</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Tab switching
        document.querySelectorAll('.tab-button').forEach(button => {
            button.addEventListener('click', () => {
                const tabName = button.dataset.tab;
                
                // Remove active class from all buttons and forms
                document.querySelectorAll('.tab-button').forEach(btn => btn.classList.remove('active'));
                document.querySelectorAll('.form-content').forEach(form => form.classList.remove('active'));
                
                // Add active class to clicked button and corresponding form
                button.classList.add('active');
                document.getElementById(tabName).classList.add('active');
            });
        });

        // Login handler
        function handleLogin(event) {
            event.preventDefault();
            const email = document.getElementById('login-email').value;
            const password = document.getElementById('login-password').value;
            
            fetch('api/auth/login', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ email, password })
            })
            .then(res => res.json())
            .then(data => {
                console.log('Login response:', data);
                if (data.success) {
                    window.location.href = 'tareas';
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(err => {
                console.error('Login error:', err);
                alert('Error en el login');
            });
        }

        // Register handler
        function handleRegister(event) {
            event.preventDefault();
            const name = document.getElementById('register-name').value;
            const email = document.getElementById('register-email').value;
            const password = document.getElementById('register-password').value;
            const passwordConfirm = document.getElementById('register-password-confirm').value;
            
            if (password !== passwordConfirm) {
                alert('Las contraseñas no coinciden');
                return;
            }
            
            fetch('api/auth/register', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ name, email, password })
            })
            .then(res => res.json())
            .then(data => {
                console.log('Register response:', data);
                if (data.success) {
                    alert('Cuenta creada exitosamente');
                    window.location.href = 'tareas';
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(err => {
                console.error('Register error:', err);
                alert('Error en el registro');
            });
        }

        // Social login handler
        function handleSocialLogin(provider) {
            console.log('Social login:', provider);
            alert('Iniciando sesión con ' + provider);
            // Here you would implement OAuth flow
        }
    </script>
</body>
</html>
